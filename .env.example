# Lava — local environment configuration template.
# Copy to `.env` and replace placeholders with real values. The `.env`
# file is gitignored (constitutional 6.H Credential Security).
#
# IMPORTANT: NEVER commit a real .env. The placeholders below are safe;
# the real values are sensitive and live only on developer machines.

# ============================================================
# Signing
# ============================================================
# Signing keystore password (used for both debug and release).
KEYSTORE_PASSWORD=your_password_here

# Directory containing the signing keystores (relative to project root).
KEYSTORE_ROOT_DIR=keystores

# ============================================================
# Tracker credentials (provider login Challenge Tests + manual smoke)
# ============================================================
# These are used by `app/build.gradle.kts` to populate BuildConfig
# fields read by the Challenge Tests at C2 and the dev-mode auto-fill.
RUTRACKER_USERNAME=your_rutracker_login
RUTRACKER_PASSWORD=your_rutracker_password
KINOZAL_USERNAME=your_kinozal_login
KINOZAL_PASSWORD=your_kinozal_password
NNMCLUB_USERNAME=your_nnmclub_login
NNMCLUB_PASSWORD=your_nnmclub_password

# ============================================================
# Firebase — for Crashlytics, Analytics, Performance, App Distribution
# ============================================================
# Firebase CLI token. Obtain via `firebase login:ci` (one-time, then store
# the printed token here). NEVER commit this value.
LAVA_FIREBASE_TOKEN=1//your-firebase-ci-token-goes-here

# Firebase project + app IDs. Get from Firebase Console → Project Settings
# → General after `firebase apps:create` runs.
LAVA_FIREBASE_PROJECT_ID=your-firebase-project-id
LAVA_FIREBASE_ANDROID_APP_ID=1:000000000000:android:0000000000000000000000
LAVA_FIREBASE_ANDROID_DEV_APP_ID=1:000000000000:android:0000000000000000000000
LAVA_FIREBASE_API_GO_APP_ID=1:000000000000:web:0000000000000000000000

# App Distribution tester roster. The list is loaded from .env at distribute
# time (see scripts/firebase-distribute.sh). Three roles by convention:
#   OWNER     — release manager / org owner
#   DEVELOPER — agent or human developer authoring the build
#   TESTER    — external QA tester
LAVA_FIREBASE_TESTERS_OWNER=owner@example.com
LAVA_FIREBASE_TESTERS_DEVELOPER=developer@example.com
LAVA_FIREBASE_TESTERS_TESTER=tester@example.com

# ============================================================
# Remote Go API distribution — for thinker.local + future hosts
# ============================================================
# scripts/distribute-api-remote.sh ships the lava-api-go OCI image
# tarball + boot script + TLS material to a remote host via SSH and
# brings the stack up under rootless Podman. The remote host MUST:
#   - be reachable at $LAVA_REMOTE_HOST_USER@$LAVA_API_GO_REMOTE_HOST
#   - have passwordless SSH (key-based auth) configured
#   - have rootless Podman 4.x or later installed
#
# Defaults match the operator's primary remote (thinker.local). Override
# either variable in your local .env to target a different host. Multi-
# host fan-out (matching the HelixAgent / Catalogizer pattern) is owed
# in a follow-up phase; for now one remote per distribute invocation.
LAVA_API_GO_REMOTE_HOST=thinker.local
LAVA_REMOTE_HOST_USER=milosvasic

# === Phase 1 (2026-05-06): API auth + transport ===

# Auth field identifier (read by both API + Android build)
LAVA_AUTH_FIELD_NAME=Lava-Auth

# Allowlist + rotation
LAVA_AUTH_CURRENT_CLIENT_NAME=android-1.2.7-1027
LAVA_AUTH_ACTIVE_CLIENTS=android-1.2.7-1027:00000000-0000-0000-0000-000000000000
LAVA_AUTH_RETIRED_CLIENTS=

# API-only
LAVA_AUTH_HMAC_SECRET=cGxhY2Vob2xkZXItcmVwbGFjZS1tZS1pbi1lbnYtZmlsZQ==
LAVA_AUTH_BACKOFF_STEPS=2s,5s,10s,30s,1m,1h
LAVA_AUTH_TRUSTED_PROXIES=
LAVA_AUTH_MIN_SUPPORTED_VERSION_NAME=1.2.6
LAVA_AUTH_MIN_SUPPORTED_VERSION_CODE=1026

# Android-build-only
LAVA_AUTH_OBFUSCATION_PEPPER=cGxhY2Vob2xkZXItcmVwbGFjZS1tZS1pbi1lbnYtZmlsZQ==

# Transport (API runtime)
LAVA_API_HTTP3_ENABLED=true
LAVA_API_BROTLI_QUALITY=4
LAVA_API_BROTLI_RESPONSE_ENABLED=true
LAVA_API_BROTLI_REQUEST_DECODE_ENABLED=false
LAVA_API_PROTOCOL_METRIC_ENABLED=true
