# Lava — distributed deployment config for thinker.local
#
# Target host: thinker.local
#   - SSH: passwordless, key-based authentication, user=milosvasic
#   - Runtime: rootless Podman 4.9.3
#   - Role: secondary lava-api-go instance (replaces local-host instance)
#
# Usage:
#   ./scripts/distribute-api-remote.sh thinker.local
#
# The script ships:
#   1. The lava-api-go OCI image tarball (via scp)
#   2. The Postgres image (already on registry)
#   3. The boot script in deployment/thinker/thinker-up.sh
#
# Constitutional bindings:
#   §6.H Credential Security — no credentials hardcoded; all values
#         come from the operator's local .env which is gitignored.
#   §6.J Anti-Bluff — script propagates failures via set -euo pipefail.
#   §6.K Builds-Inside-Containers — image is produced by build_and_release.sh
#         (which routes through the project's container build path).
#   §6.M Host-Stability — no power-management commands; remote operations
#         are session-scoped Podman calls.

# Network for the Lava stack on thinker.local (rootless, isolated).
LAVA_THINKER_NETWORK=lava-thinker

# Port mappings (bound to 0.0.0.0 so LAN clients reach the API; thinker is
# the operator's LAN host and is meant to be reachable from the Android
# devices running Lava).
LAVA_THINKER_API_PORT=8443
LAVA_THINKER_POSTGRES_PORT=5432
LAVA_THINKER_METRICS_PORT=9091

# Container names — distinct from local-host container names so the
# operator can run both side-by-side during cutover.
LAVA_THINKER_API_NAME=lava-api-go-thinker
LAVA_THINKER_POSTGRES_NAME=lava-postgres-thinker

# Resource budgets (thinker has 30 GB RAM + GPU; Lava's footprint is
# small but we set explicit limits so other workloads on thinker keep
# their share).
LAVA_THINKER_API_CPUS=2
LAVA_THINKER_API_MEMORY=2g
LAVA_THINKER_POSTGRES_CPUS=1
LAVA_THINKER_POSTGRES_MEMORY=1g

# Postgres credentials — for the dedicated thinker instance only.
# These are NOT the local-host Postgres credentials; the thinker
# database is a fresh, isolated Postgres on thinker.local.
LAVA_THINKER_POSTGRES_USER=lava
LAVA_THINKER_POSTGRES_PASSWORD=lava-thinker-default
LAVA_THINKER_POSTGRES_DB=lava

# Remote paths.
LAVA_THINKER_REMOTE_DIR=/home/milosvasic/lava
LAVA_THINKER_IMAGE_TAR=/tmp/lava-api-go-thinker.image.tar

# TLS: thinker reuses the same self-signed cert + key the local instance
# uses. The remote-distribute script copies them to the remote on each
# distribute. For production cutover, generate per-host certs.
LAVA_THINKER_TLS_CERT=/home/milosvasic/lava/tls/server.crt
LAVA_THINKER_TLS_KEY=/home/milosvasic/lava/tls/server.key
