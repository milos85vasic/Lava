<?xml version="1.0" encoding="utf-8"?>
<!--
  Lava network security policy.

  SP-3.1 (2026-04-29). The user-installed-CA path was REMOVED because
  it required an operator side-loading the lava-api-go self-signed CA
  via Settings → Security → Install certificate — a manual step
  forbidden by the project's Sixth-Law clause 4 (a feature the user
  cannot complete without device-settings detours is not shippable).

  TLS to the LAN api-go is now handled at the OkHttp layer via a
  permissive @Named("lan") OkHttpClient — see
  core/network/impl/.../NetworkModule.kt KDoc on lanOkHttpClient for
  the trust-boundary rationale. This NSC file therefore only handles
  cleartext-on-LAN (for the legacy Ktor proxy at http://lan-ip:8080).
-->
<network-security-config>
    <!--
      Default for any address not matched by domain-config below.
      Cleartext is allowed because the legacy LAN proxy uses
      http://192.168.x.y:8080. TLS uses the system trust store —
      this is the strict path for public-Internet endpoints
      (lava-app.tech, rutracker.org and mirrors).
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!--
      Domain-level cleartext-OK list for LAN ranges. Used by the
      legacy-proxy code path (Endpoint.Mirror with isLocalHost()).

      The `lava-api-go` HTTPS path on port 8443 does NOT depend on
      this section — that path is wired through the LAN-permissive
      OkHttpClient and bypasses NSC's trust-anchor resolution
      entirely.

      LAN entries: localhost + .local (for mDNS) + the most common
      home-LAN gateway IPs. The DSL doesn't accept CIDR ranges.
      Operators on different subnets won't need to edit this — the
      LAN-permissive OkHttpClient handles HTTPS regardless. They
      only need to add an entry here if they want plaintext HTTP
      for the legacy proxy on a non-default LAN prefix.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="true">local</domain>
        <domain includeSubdomains="false">192.168.1.1</domain>
        <domain includeSubdomains="false">192.168.1.2</domain>
        <domain includeSubdomains="false">192.168.0.1</domain>
        <domain includeSubdomains="false">10.0.0.1</domain>
        <domain includeSubdomains="false">10.0.0.2</domain>

        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
