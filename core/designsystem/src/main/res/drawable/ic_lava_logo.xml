<?xml version="1.0" encoding="utf-8"?>
<!--
  Full-color Lava brand logo composited from the launcher background +
  foreground layers shipped at five densities (mdpi → xxxhdpi).

  Used by the onboarding Welcome screen and any future surface that
  needs the colored brand mark. NOT to be confused with `ic_notification`
  (the monochrome notification glyph required by Android's notification
  system) which lives at `R.drawable.ic_notification` in this same module.

  Forensic anchor: the pre-fix `LavaIcons.AppIcon = R.drawable.ic_notification`
  caused the WelcomeStep title-bar logo to render as a black-and-white
  glyph reported by the operator on 2026-05-14. This drawable is the
  colored replacement; `LavaIcons.AppIcon` now points here.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@drawable/ic_lava_logo_background" />
    <item android:drawable="@drawable/ic_lava_logo_foreground" />
</layer-list>
