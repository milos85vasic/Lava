#!/usr/bin/env bash
# .githooks/pre-push — layered Anti-Bluff + Local-Only CI gate.
#
# Layer 1 (Seventh Law mechanical enforcement, added 2026-04-30):
#   - Reject hosted-CI configs (Local-Only CI/CD rule).
#   - Reject test commits without a Bluff-Audit: stamp.
#   - Reject mock-the-SUT pattern (mockk<XxxClass> in XxxClassTest.kt).
#
# Layer 2 (SP-3a Phase 5 Task 5.20, added 2026-04-30):
#   - Run scripts/ci.sh --changed-only as the local CI gate. This is
#     the same script developers run by hand and the same that runs
#     at tag time; it is the single source of truth for "shippable".
#
# Layer 2 dedup cache (SP-2 hook patch, 2026-04-30):
#   - Mirror-policy pushes the same SHA to four upstreams in sequence;
#     re-running scripts/ci.sh --changed-only against the same SHA on
#     every push is purely redundant work because the gate's input
#     (the SHA's tree) is identical on each invocation. The cache at
#     .lava-ci-evidence/.pre-push-verified-shas (gitignored) records
#     the SHAs verified in the last LAVA_PRE_PUSH_DEDUP_TTL seconds
#     (default 3600). When every pushed SHA is in the cache and is
#     fresh, Layer 2 is skipped with an explicit log message. Layer 1
#     remains unconditional. Disable the cache with
#     LAVA_PRE_PUSH_DEDUP_DISABLE=1 or LAVA_PRE_PUSH_DEDUP_TTL=0.
#
# The two layers are cumulative: violations in either layer reject the
# push. Layer 1 is the cheap, surgical check; Layer 2 is the broad
# script-driven gate.
#
# Bypass with --no-verify ONLY in operator-documented emergencies (root
# CLAUDE.md "Local-Only CI/CD" section). Routine bypass is itself a
# Seventh Law incident and MUST be noted in the next commit message.

set -euo pipefail

remote=$1
url=$2

# Determine the range of commits being pushed.
zero=0000000000000000000000000000000000000000
violations=()
pushed_shas=()

while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$local_sha" == "$zero" ]]; then
    # Branch deletion — nothing to check.
    continue
  fi

  if [[ "$remote_sha" == "$zero" ]]; then
    # New branch — check all commits reachable from local_sha but
    # not from any other ref the remote already has.
    range=$(git rev-list "$local_sha" --not --remotes="$remote" | head -200)
  else
    range=$(git rev-list "$remote_sha..$local_sha")
  fi

  for sha in $range; do
    # Track every pushed SHA so the multi-mirror dedup cache below
    # knows what to look up / record.
    pushed_shas+=("$sha")
    # ===== Check 1: Hosted-CI config introduction (Local-Only CI/CD rule) =====
    if git diff-tree --no-commit-id --name-only -r "$sha" | grep -qE '^(\.github/workflows/|\.gitlab-ci\.yml|\.circleci/|azure-pipelines\.yml|bitbucket-pipelines\.yml|Jenkinsfile|appveyor\.yml|travis\.yml)'; then
      violations+=("$sha: introduces hosted-CI config (Local-Only CI/CD rule). Routine bypass forbidden.")
    fi

    # ===== Check 2: Test commits MUST carry a Bluff-Audit stamp =====
    test_files=$(git diff-tree --no-commit-id --name-only -r "$sha" | grep -E '(Test\.kt|_test\.go)$' || true)
    if [[ -n "$test_files" ]]; then
      msg=$(git log -1 --pretty=%B "$sha")
      if ! grep -qE '^Bluff-Audit:' <<<"$msg"; then
        violations+=("$sha: adds/modifies test files without Bluff-Audit: stamp (Seventh Law clause 1). Files: $(echo "$test_files" | tr '\n' ' ')")
      fi
    fi

    # ===== Check 3: Forbidden test patterns =====
    # 3a — Mocking the SUT (mockk<XxxClass> in XxxClassTest.kt)
    diff_added=$(git diff-tree -p --no-commit-id "$sha" -- '*Test.kt' 2>/dev/null | grep -E '^\+[^+]' || true)
    if [[ -n "$diff_added" ]]; then
      # Find any `mockk<X>(...)` where X matches the test class name root.
      while IFS= read -r f; do
        if [[ -z "$f" ]]; then continue; fi
        class_root=$(basename "$f" .kt | sed 's/Test$//')
        if [[ -z "$class_root" ]]; then continue; fi
        if git diff-tree -p --no-commit-id "$sha" -- "$f" 2>/dev/null | \
           grep -qE "^\+.*mockk<\s*${class_root}\s*>"; then
          violations+=("$sha: $f mocks the System Under Test (${class_root}). Forbidden test pattern (Seventh Law clause 4).")
        fi
      done <<<"$test_files"
    fi

    # ===== Check 4: §6.N.1.2 — gate-shaping file change requires Bluff-Audit
    # stamp targeting a file in the diff. List extended 2026-05-14 (1.2.23
    # cycle) to include .githooks/pre-push (the hook itself is gate-shaping)
    # + scripts/firebase-distribute.sh (release-gate script) per §6.AD-debt
    # closure-cycle audit. =====
    gate_files=$(git diff-tree --no-commit-id --name-only -r "$sha" | \
      grep -E '^(submodules/containers/pkg/emulator/.*\.go|scripts/run-emulator-tests\.sh|scripts/tag\.sh|scripts/check-constitution\.sh|scripts/firebase-distribute\.sh|\.githooks/pre-push)$' || true)
    if [[ -n "$gate_files" ]]; then
      msg=$(git log -1 --pretty=%B "$sha")
      if ! grep -qE '^Bluff-Audit:' <<<"$msg"; then
        violations+=("$sha: §6.N.1.2 violation — touches gate-shaping file(s) without Bluff-Audit stamp. Files: $(echo "$gate_files" | tr '\n' ' ')")
      else
        # Stamp present — verify it NAMES at least one file in the diff.
        diff_files=$(git diff-tree --no-commit-id --name-only -r "$sha")
        # Extract path tokens from the commit message. Two patterns:
        # (1) Anything with one of the canonical extensions
        # (2) Extensionless paths in well-known script dirs (.githooks/*) —
        #     added 2026-05-14 so a stamp can target .githooks/pre-push itself.
        stamp_paths=$( { \
          grep -oE '[a-zA-Z0-9_/.-]+\.(go|kt|kts|sh|json|md|xml|yaml|yml)' <<<"$msg" || true; \
          grep -oE '\.githooks/[a-zA-Z0-9_-]+' <<<"$msg" || true; \
        } | sort -u)
        match_found=false
        while IFS= read -r df; do
          [[ -z "$df" ]] && continue
          if grep -qF "$df" <<<"$stamp_paths"; then
            match_found=true
            break
          fi
        done <<<"$diff_files"
        if [[ "$match_found" != "true" ]]; then
          violations+=("$sha: §6.N.1.2 violation — Bluff-Audit stamp present but does NOT name any file in the diff. Diff: $(echo "$diff_files" | tr '\n' ' ') Stamp paths: $(echo "$stamp_paths" | tr '\n' ' ')")
        fi
      fi
    fi

    # ===== Check 6: §6.Y bump-first ordering =====
    # Closes §6.Y-debt. After a successful distribute (last-version-{debug,release}
    # advanced), the FIRST commit in the new development cycle that touches code
    # MUST bump versionCode. Detection: the commit's tree diff contains non-doc
    # source files AND working-tree app/build.gradle.kts versionCode equals
    # last-published-versionCode. The check fires only when versionCode in the
    # diff is unchanged AND the diff contains code surfaces.
    if git diff-tree --no-commit-id --name-only -r "$sha" | grep -qE '^(app/.*\.(kt|kts|xml|json)|core/.*\.(kt|kts|xml)|feature/.*\.(kt|kts|xml)|lava-api-go/.*\.go)$'; then
      # Did THIS commit bump the versionCode in app/build.gradle.kts?
      if git diff-tree --no-commit-id --name-only -r "$sha" | grep -qF 'app/build.gradle.kts'; then
        # versionCode line changed in this commit — OK
        :
      else
        # No version bump in this commit; check working-tree versionCode against
        # the last-published last-version-debug pointer.
        ver_pointer_debug=".lava-ci-evidence/distribute-changelog/firebase-app-distribution/last-version-debug"
        if [[ -f "$ver_pointer_debug" ]]; then
          last_published=$(cat "$ver_pointer_debug" 2>/dev/null | tr -d ' \n' || echo "")
          # Read the versionCode at this commit's tree
          commit_vc=$(git show "$sha:app/build.gradle.kts" 2>/dev/null | grep -oE 'versionCode[[:space:]]*=[[:space:]]*[0-9]+' | head -1 | grep -oE '[0-9]+' || echo "")
          if [[ -n "$last_published" && -n "$commit_vc" && "$commit_vc" -le "$last_published" ]]; then
            # Allow if commit message body mentions "constitutional-plumbing-only" OR is doc-only label
            msg=$(git log -1 --pretty=%B "$sha")
            if ! grep -qE 'constitutional-plumbing-only|docs?-only|version-bump-only|bump-first' <<<"$msg"; then
              violations+=("$sha: §6.Y violation — touches code (.kt/.kts/.xml/.json/.go) without bumping versionCode (commit's vc=$commit_vc <= last-published-debug=$last_published). Either bump versionCode in this commit OR add a 'constitutional-plumbing-only' rationale line to the commit body.")
            fi
          fi
        fi
      fi
    fi

    # ===== Check 7: §6.Z evidence-file presence on distribute-advancing commits =====
    # Closes §6.Z-debt (companion to firebase-distribute.sh's runtime gate). When
    # a commit ACTUALLY advances last-version-debug or last-version-release (NEW
    # value > OLD value), a companion evidence file at
    # .lava-ci-evidence/distribute-changelog/firebase-app-distribution/<vname>-<NEW>-test-evidence.{md,json}
    # MUST exist. Touch-without-value-change is NOT an advance.
    for ptr in last-version-debug last-version-release; do
      ptr_path=".lava-ci-evidence/distribute-changelog/firebase-app-distribution/${ptr}"
      if git diff-tree --no-commit-id --name-only -r "$sha" 2>/dev/null | grep -qF "$ptr_path"; then
        old_val=$(git show "$sha^:$ptr_path" 2>/dev/null | tr -d ' \n' || echo "0")
        new_val=$(git show "$sha:$ptr_path" 2>/dev/null | tr -d ' \n' || echo "0")
        # Coerce to integer; if either is non-numeric, treat as no-advance.
        if [[ "$new_val" =~ ^[0-9]+$ && "$old_val" =~ ^[0-9]+$ && "$new_val" -gt "$old_val" ]]; then
          # Real advance — find the version-name that distributed this code.
          # Canonical lookup: per-version snapshot file `<vname>-<new_val>.md`
          # in same directory (firebase-distribute.sh writes both pointer +
          # snapshot atomically). If the snapshot is absent, fall back to
          # build.gradle.kts versionName at this commit.
          vname=""
          snapshot=$(ls .lava-ci-evidence/distribute-changelog/firebase-app-distribution/*-${new_val}.md 2>/dev/null | grep -v '\-test-evidence\.md$' | head -1 || true)
          if [[ -n "$snapshot" ]]; then
            vname=$(basename "$snapshot" -${new_val}.md)
          else
            vname=$(git show "$sha:app/build.gradle.kts" 2>/dev/null | grep -oE 'versionName[[:space:]]*=[[:space:]]*"[^"]+"' | head -1 | sed 's/.*"\([^"]*\)".*/\1/' || echo "")
          fi
          if [[ -n "$vname" ]]; then
            evidence_md=".lava-ci-evidence/distribute-changelog/firebase-app-distribution/${vname}-${new_val}-test-evidence.md"
            evidence_json=".lava-ci-evidence/distribute-changelog/firebase-app-distribution/${vname}-${new_val}-test-evidence.json"
            if [[ ! -f "$evidence_md" && ! -f "$evidence_json" ]]; then
              violations+=("$sha: §6.Z violation — advances $ptr ${old_val}→${new_val} for ${vname} but no test-evidence file at $evidence_md (or .json). The §6.Z mandate requires pre-distribute test execution evidence with matching commit SHA.")
            fi
          fi
        fi
      fi
    done

    # ===== Check 9: §11.4.18 / CM-SCRIPT-DOCS-SYNC — script doc sync =====
    # Closes CM-SCRIPT-DOCS-SYNC. When a commit modifies scripts/X.sh, the
    # companion docs/scripts/X.sh.md MUST be modified in the SAME commit
    # (per HelixConstitution §11.4.18). Exemption: if no companion doc
    # exists yet (first commit of a new script), the next commit MUST add
    # the companion — but this gate doesn't enforce that follow-up.
    diff_files=$(git diff-tree --no-commit-id --name-only -r "$sha")
    while IFS= read -r f; do
      [[ "$f" =~ ^scripts/.*\.sh$ ]] || continue
      script_basename=$(basename "$f")
      doc_path="docs/scripts/${script_basename}.md"
      # If the doc exists AT THIS COMMIT, it must have been touched in this commit.
      if git cat-file -e "$sha:$doc_path" 2>/dev/null; then
        if ! grep -qF "$doc_path" <<<"$diff_files"; then
          violations+=("$sha: §11.4.18/CM-SCRIPT-DOCS-SYNC violation — modifies $f without modifying companion $doc_path in the same commit. Add the doc update to this commit, OR use commit_all.sh --no-push first to amend.")
        fi
      fi
    done <<<"$diff_files"

    # ===== Check 8: §11.4.17 Classification: line on new-rule commits =====
    # Closes §6.AD-debt item 6. When a commit adds a new constitutional clause
    # (line matching ^##### 6\.[A-Z]+ — added) to CLAUDE.md, the commit body
    # MUST carry a `Classification:` line per HelixConstitution §11.4.17.
    new_clauses=$(git diff-tree -p --no-commit-id "$sha" -- CLAUDE.md 2>/dev/null | grep -E '^\+##### 6\.[A-Z]+' | head -3 || true)
    if [[ -n "$new_clauses" ]]; then
      msg=$(git log -1 --pretty=%B "$sha")
      if ! grep -qE '^Classification:' <<<"$msg"; then
        violations+=("$sha: §11.4.17 violation — adds a new ##### 6.X clause to CLAUDE.md without a 'Classification:' line in the commit body. Add 'Classification: universal' or 'Classification: project-specific' (or 'Classification: mixed') with a one-sentence rationale.")
      fi
    fi

    # ===== Check 5: §6.N.1.3 — new attestation file requires falsifiability
    # rehearsal evidence (in-JSON, companion file, or commit-body Bluff-Audit) =====
    new_attestations=$(git diff-tree --no-commit-id --name-only --diff-filter=A -r "$sha" | \
      grep -E '^(\.lava-ci-evidence/sp3a-challenges/.*\.(json|md)|\.lava-ci-evidence/[^/]+/real-device-verification\.(json|md)|\.lava-ci-evidence/sixth-law-incidents/.*\.json)$' | \
      grep -v '\.rehearsal\.' || true)
    if [[ -n "$new_attestations" ]]; then
      msg=$(git log -1 --pretty=%B "$sha")
      while IFS= read -r f; do
        [[ -z "$f" ]] && continue
        # (1) Embedded in JSON?
        embedded=false
        if [[ "$f" =~ \.json$ ]] && command -v jq >/dev/null 2>&1; then
          if jq -e '.falsifiability_rehearsal // .Bluff_Audit // .bluff_classification // .primary_finding.bluff_classification' "$f" >/dev/null 2>&1; then
            embedded=true
          fi
        fi
        # (2) Companion file?
        companion=false
        stem="${f%.*}"
        for ext in json md; do
          if [[ -f "$stem.rehearsal.$ext" ]]; then
            companion=true
            break
          fi
        done
        # (3) Commit-body Bluff-Audit referencing the path?
        commit_ref=false
        if grep -qE '^Bluff-Audit:' <<<"$msg" && grep -qF "$f" <<<"$msg"; then
          commit_ref=true
        fi
        if [[ "$embedded" != "true" && "$companion" != "true" && "$commit_ref" != "true" ]]; then
          violations+=("$sha: §6.N.1.3 violation — added attestation $f without falsifiability rehearsal. Accept: (1) embed falsifiability_rehearsal/Bluff_Audit/bluff_classification block in $f; OR (2) ship $stem.rehearsal.{json,md} alongside; OR (3) add Bluff-Audit stamp in commit body referencing $f.")
        fi
      done <<<"$new_attestations"
    fi
  done
done

if [[ ${#violations[@]} -gt 0 ]]; then
  echo "==============================================================="
  echo "PRE-PUSH HOOK REJECTED PUSH — Seventh Law violations detected"
  echo "==============================================================="
  for v in "${violations[@]}"; do
    echo "  - $v"
  done
  echo "---------------------------------------------------------------"
  echo "Each violation MUST be resolved before the push can proceed."
  echo "Routine bypass (--no-verify) is itself a Seventh Law incident."
  echo "Documented emergencies: cite the incident ID in the next commit."
  echo "==============================================================="
  exit 1
fi

# ===== Layer 2: scripts/ci.sh --changed-only =====
# Per SP-3a Phase 5 Task 5.20: the pre-push hook runs the same local
# CI gate that runs at tag time, in --changed-only mode (Spotless,
# unit tests on tracker modules, constitutional doc parser, forbidden-
# files check, host-power command check). Heavier gates (parity,
# fixture-freshness, Compose UI Challenge Tests) are deferred to
# --full mode at tag time.
#
# If the operator wishes to push a WIP commit and run the gate
# manually later, they can bypass with --no-verify and document the
# emergency per the Local-Only CI/CD rule.
#
# ===== Multi-mirror dedup cache (SP-2 hook patch, 2026-04-30) =====
# Forensic anchor: SP-3a Step 6+7 implementer used --no-verify on 3 of
# 4 mirror pushes because re-running scripts/ci.sh --changed-only for
# the same SHA on every mirror is purely redundant. Re-running an
# identical gate against an identical SHA produces an identical
# answer; the only thing that differs across pushes is the remote
# being targeted, which Layer 2 does not look at.
#
# Resolution: cache the SHAs that have already passed Layer 2 in this
# environment, and skip re-running Layer 2 if the SHA appears in the
# cache and was verified within the configured TTL (default 1h). The
# cache is local-only, gitignored, and entirely advisory — Layer 1 is
# unconditional, and a cache miss falls back to running the full
# gate. This is permitted by the Local-Only CI/CD rule because the
# gate itself is identical; we are merely deduping invocations.
#
# Cache file format: one line per verified SHA, "<sha> <epoch>".
# TTL: LAVA_PRE_PUSH_DEDUP_TTL seconds (default 3600). Setting it to
# 0 disables the cache (Layer 2 always runs, like the pre-patch
# behaviour). Setting LAVA_PRE_PUSH_DEDUP_DISABLE=1 also disables.
DEDUP_CACHE_DIR=".lava-ci-evidence"
DEDUP_CACHE_FILE="${DEDUP_CACHE_DIR}/.pre-push-verified-shas"
DEDUP_TTL="${LAVA_PRE_PUSH_DEDUP_TTL:-3600}"
DEDUP_DISABLED="${LAVA_PRE_PUSH_DEDUP_DISABLE:-0}"

# Determine whether ALL pushed local SHAs have a fresh cache entry.
# pushed_shas is populated in the per-SHA loop above. A cache hit on
# every pushed SHA means Layer 2 was already run successfully against
# this exact SHA set within the TTL — re-running it would produce the
# same result on the same input. A cache miss on any SHA falls back
# to running Layer 2 as normal, after which the cache is refreshed.
all_shas_cached=true
if [[ "$DEDUP_DISABLED" != "1" && "$DEDUP_TTL" -gt 0 && ${#pushed_shas[@]} -gt 0 && -f "$DEDUP_CACHE_FILE" ]]; then
  now=$(date +%s)
  for sha in "${pushed_shas[@]}"; do
    cached_line=$(grep -E "^${sha} " "$DEDUP_CACHE_FILE" 2>/dev/null || true)
    if [[ -z "$cached_line" ]]; then
      all_shas_cached=false
      break
    fi
    cached_ts="${cached_line##* }"
    age=$(( now - cached_ts ))
    if [[ "$age" -ge "$DEDUP_TTL" ]]; then
      all_shas_cached=false
      break
    fi
  done
else
  all_shas_cached=false
fi

if [[ ${#pushed_shas[@]} -gt 0 && "$all_shas_cached" == "true" ]]; then
  echo "==============================================================="
  echo "Pre-push: skipping Layer 2 (scripts/ci.sh --changed-only)"
  echo "  reason: all ${#pushed_shas[@]} pushed SHA(s) already verified"
  echo "  cache:  $DEDUP_CACHE_FILE (TTL=${DEDUP_TTL}s)"
  for sha in "${pushed_shas[@]}"; do
    cached_line=$(grep -E "^${sha} " "$DEDUP_CACHE_FILE" 2>/dev/null || true)
    cached_ts="${cached_line##* }"
    if [[ -n "$cached_ts" ]]; then
      ts_human=$(date -d "@${cached_ts}" '+%Y-%m-%dT%H:%M:%SZ' -u 2>/dev/null || echo "$cached_ts")
      echo "    - $sha verified at $ts_human"
    fi
  done
  echo "==============================================================="
  exit 0
fi

if [[ -x ./scripts/ci.sh ]]; then
  echo "==============================================================="
  echo "Pre-push: invoking scripts/ci.sh --changed-only (SP-3a Layer 2)"
  echo "==============================================================="
  if ! ./scripts/ci.sh --changed-only; then
    echo "==============================================================="
    echo "PRE-PUSH HOOK REJECTED PUSH — scripts/ci.sh --changed-only failed"
    echo "==============================================================="
    echo "Routine bypass (--no-verify) is itself a Seventh Law incident."
    echo "==============================================================="
    exit 1
  fi

  # Layer 2 passed — refresh the cache for every pushed SHA so that
  # subsequent pushes of the same SHA(s) to other mirrors skip the
  # redundant re-run.
  if [[ "$DEDUP_DISABLED" != "1" && "$DEDUP_TTL" -gt 0 && ${#pushed_shas[@]} -gt 0 ]]; then
    mkdir -p "$DEDUP_CACHE_DIR"
    now=$(date +%s)
    # Strip any pre-existing entries for the SHAs we are about to
    # re-add; rewrite cache atomically. Old entries beyond the TTL
    # are also pruned in the same pass.
    tmp_cache="${DEDUP_CACHE_FILE}.tmp.$$"
    : > "$tmp_cache"
    if [[ -f "$DEDUP_CACHE_FILE" ]]; then
      while IFS=' ' read -r line_sha line_ts; do
        # Drop empties and stale entries.
        [[ -z "$line_sha" ]] && continue
        [[ -z "$line_ts" ]] && continue
        age=$(( now - line_ts ))
        [[ "$age" -ge "$DEDUP_TTL" ]] && continue
        # Drop entries we are about to replace.
        skip=false
        for sha in "${pushed_shas[@]}"; do
          if [[ "$sha" == "$line_sha" ]]; then
            skip=true; break
          fi
        done
        $skip && continue
        printf '%s %s\n' "$line_sha" "$line_ts" >>"$tmp_cache"
      done <"$DEDUP_CACHE_FILE"
    fi
    for sha in "${pushed_shas[@]}"; do
      printf '%s %s\n' "$sha" "$now" >>"$tmp_cache"
    done
    mv "$tmp_cache" "$DEDUP_CACHE_FILE"
    echo "==============================================================="
    echo "Pre-push: cached ${#pushed_shas[@]} verified SHA(s) in $DEDUP_CACHE_FILE"
    echo "==============================================================="
  fi
fi

exit 0
